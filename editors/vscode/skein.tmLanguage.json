{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Skein",
  "scopeName": "source.skein",
  "fileTypes": ["skein"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#constant" },
    { "include": "#annotation" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#function-definition" },
    { "include": "#function-reference" },
    { "include": "#operator" },
    { "include": "#punctuation" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-dash.skein",
      "match": "--.*$"
    },
    "string": {
      "name": "string.quoted.double.skein",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.skein",
          "match": "\\\\[\\\\\"nrt0]"
        },
        {
          "name": "meta.interpolation.skein",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.skein" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.skein" }
          },
          "patterns": [
            { "include": "source.skein" }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.skein",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.skein",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.boolean.skein",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.skein",
          "match": "\\b(Ok|Err|Some|None)\\b"
        }
      ]
    },
    "annotation": {
      "patterns": [
        {
          "name": "meta.annotation.skein",
          "match": "(@)(\\w+)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.skein" },
            "2": { "name": "entity.name.decorator.skein" }
          }
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.skein",
          "match": "\\b(match|on|emit|transition|return|stop|suspend|resume|replay|given|expect|assert)\\b"
        },
        {
          "name": "keyword.declaration.skein",
          "match": "\\b(module|fn|let|type|enum|handler|agent|tool|capability|supervisor|test|scenario|golden|implement|input|output|errors|policy|description|state|phase|strategy|child|pub|extern|import|from)\\b"
        },
        {
          "name": "keyword.other.http-method.skein",
          "match": "\\b(GET|POST|PUT|PATCH|DELETE)\\b"
        },
        {
          "name": "keyword.other.stdlib.skein",
          "match": "\\b(idempotent|respond|store|memory|event|llm|topic|queue|task|stream|trace|config|secret|http|schedule)\\b"
        }
      ]
    },
    "type": {
      "patterns": [
        {
          "name": "support.type.primitive.skein",
          "match": "\\b(Int|Float|String|Bool|Uuid|Instant|Duration|Email|Url|Option|Result|List|Map|Set)\\b"
        },
        {
          "comment": "User-defined types and enum variants (PascalCase identifiers)",
          "name": "entity.name.type.skein",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "function-definition": {
      "match": "\\b(fn)\\s+([a-z][a-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.skein" },
        "2": { "name": "entity.name.function.skein" }
      }
    },
    "function-reference": {
      "match": "(&)([a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*)",
      "captures": {
        "1": { "name": "punctuation.definition.reference.skein" },
        "2": { "name": "entity.name.function.reference.skein" }
      }
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.skein",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.skein",
          "match": "->"
        },
        {
          "name": "keyword.operator.fat-arrow.skein",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.skein",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.skein",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.skein",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.skein",
          "match": "="
        },
        {
          "name": "keyword.operator.unwrap.skein",
          "match": "[!?]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.skein",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.skein",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.skein",
          "match": "\\."
        }
      ]
    },
    "identifier": {
      "name": "variable.other.skein",
      "match": "\\b[a-z][a-z0-9_]*\\b"
    }
  }
}
