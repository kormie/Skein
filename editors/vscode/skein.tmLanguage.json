{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Skein",
  "scopeName": "source.skein",
  "fileTypes": ["skein"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#annotations" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.skein",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.skein",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.skein",
              "match": "\\\\[\\\\\"nrt0]"
            },
            {
              "name": "meta.interpolation.skein",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.skein" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.skein" }
              },
              "patterns": [
                { "include": "source.skein" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.skein",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.skein",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.skein",
          "match": "\\b(match|on|transition|return|suspend|emit|import|from)\\b"
        },
        {
          "name": "keyword.declaration.skein",
          "match": "\\b(module|fn|let|type|enum|agent|handler|tool|capability|supervisor|test|scenario|golden|state|phase|implement|policy|input|output|errors|pub|extern)\\b"
        },
        {
          "name": "keyword.other.skein",
          "match": "\\b(idempotent|respond|store|memory|event|llm|topic|queue|task|stream|trace|config|secret|http|schedule)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.skein",
          "match": "\\b(Int|Float|String|Bool|Uuid|Instant|Duration|Email|Url|Option|Result|List|Map|Set)\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.skein",
          "match": "@(min|max|default|one_of|description|pattern|primary|unique|optional|index|check|examples|deprecated)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.skein",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.skein",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.skein",
          "match": "\\b(None|Ok|Err|Some)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.skein",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.skein",
          "match": "->"
        },
        {
          "name": "keyword.operator.fat-arrow.skein",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.skein",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.skein",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.skein",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.skein",
          "match": "="
        },
        {
          "name": "keyword.operator.error-propagation.skein",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.unwrap.skein",
          "match": "!"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.skein",
          "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.skein" },
            "2": { "name": "entity.name.function.skein" }
          }
        },
        {
          "name": "meta.function-call.skein",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.skein" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.skein",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.skein",
          "match": ","
        }
      ]
    }
  }
}
