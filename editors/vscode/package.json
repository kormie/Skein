{
  "name": "skein-lang",
  "displayName": "Skein Language",
  "description": "Full language support for the Skein programming language — syntax highlighting, diagnostics, completions, hover, go-to-definition, and more.",
  "version": "0.1.2",
  "publisher": "kormie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kormie/Skein"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "skein",
    "beam",
    "erlang",
    "elixir",
    "agent",
    "llm"
  ],
  "activationEvents": [
    "onLanguage:skein"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "skein.restartServer",
        "title": "Restart Language Server",
        "category": "Skein"
      },
      {
        "command": "skein.showServerOutput",
        "title": "Show Language Server Output",
        "category": "Skein"
      }
    ],
    "languages": [
      {
        "id": "skein",
        "aliases": ["Skein", "skein"],
        "extensions": [".skein"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skein",
        "scopeName": "source.skein",
        "path": "./skein.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "skein",
        "path": "./snippets/skein.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Skein",
      "properties": {
        "skein.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Skein Language Server for diagnostics, completions, and more."
        },
        "skein.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Working directory for the language server. If empty, the workspace root is used. Only needs to point at a Skein compiler checkout when using the mix server command."
        },
        "skein.lsp.serverCommand": {
          "type": "string",
          "enum": ["auto", "skein", "mix"],
          "default": "auto",
          "description": "How to launch the language server: 'skein' runs 'skein lsp' from the standalone binary (no Elixir needed), 'mix' runs 'mix skein.lsp' in a Skein compiler checkout, 'auto' picks mix only when the project path is a Skein compiler repo."
        },
        "skein.lsp.skeinPath": {
          "type": "string",
          "default": "skein",
          "description": "Path to the skein binary used for 'skein lsp' (default: skein on PATH)."
        },
        "skein.lsp.mixCommand": {
          "type": "string",
          "default": "mix",
          "description": "Path to the mix executable."
        },
        "skein.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace communication between VS Code and the Skein Language Server."
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "skein",
        "scopes": {
          "namespace": ["entity.name.namespace.skein"],
          "type": ["support.type.skein"],
          "class": ["entity.name.type.skein"],
          "enum": ["entity.name.type.enum.skein"],
          "function": ["entity.name.function.skein"],
          "method": ["support.function.effect.skein"],
          "variable": ["variable.other.skein"],
          "parameter": ["variable.parameter.skein"],
          "property": ["variable.other.property.skein"],
          "keyword": ["keyword.control.skein"],
          "comment": ["comment.line.double-dash.skein"],
          "string": ["string.quoted.double.skein"],
          "number": ["constant.numeric.skein"],
          "operator": ["keyword.operator.skein"],
          "decorator": ["entity.name.decorator.skein"]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
