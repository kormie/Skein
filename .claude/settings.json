{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/plugins/github-pages-astro/hooks/docs-freshness-check.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/plugins/github-pages-astro/hooks/stop-dev-server.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mix *)",
      "Bash(elixir *)",
      "Bash(erl *)",
      "Bash(cd *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(git *)",
      "Bash(mise *)",
      "Bash(chmod *)",
      "Bash(PATH=* mix *)",
      "Bash(PATH=* elixir *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(pkill *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ]
  }
}
