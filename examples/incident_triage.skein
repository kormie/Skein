-- incident_triage.skein
-- A multi-phase agent for triaging production incidents.
-- Demonstrates memory usage, LLM classification, phase transitions,
-- and suspend/resume for human escalation review.

agent IncidentTriage {
  capability model("anthropic", "claude-opus-4-8")
  capability memory.kv

  state {
    alert_id: String
    severity: String
    summary: String
  }

  enum Phase {
    Classify -> [Investigate, Ignore]
    Investigate -> [Escalate, Resolve]
    Escalate -> [Resolve]
    Ignore -> [Complete]
    Resolve -> [Complete]
    Complete -> []
  }

  on start(alert_id: String) -> {
    memory.put("alert_id", alert_id)
    transition(Phase.Classify)
  }

  on phase(Phase.Classify) -> {
    let data = memory.get("alert_id")!
    let severity = llm.chat(
      "claude-opus-4-8",
      "Classify this incident severity. Answer with exactly one word: critical, normal, or noise.",
      data
    )!
    memory.put("severity", severity)

    match String.trim(severity) {
      "noise" -> transition(Phase.Ignore)
      _ -> transition(Phase.Investigate)
    }
  }

  on phase(Phase.Investigate) -> {
    let severity = memory.get("severity")!
    let data = memory.get("alert_id")!
    let analysis = llm.chat("claude-opus-4-8", "Investigate root cause", data)!
    memory.put("analysis", analysis)

    match String.trim(severity) {
      "critical" -> transition(Phase.Escalate)
      _ -> transition(Phase.Resolve)
    }
  }

  on phase(Phase.Escalate) -> {
    let alert = memory.get("alert_id")!
    emit IncidentEscalated { alert_id: alert }
    suspend("Awaiting on-call engineer")
  }

  on phase(Phase.Ignore) -> {
    let alert = memory.get("alert_id")!
    emit IncidentIgnored { alert_id: alert }
    transition(Phase.Complete)
  }

  on phase(Phase.Resolve) -> {
    let alert = memory.get("alert_id")!
    let analysis = memory.get("analysis")!
    emit IncidentResolved { alert_id: alert, analysis: analysis }
    transition(Phase.Complete)
  }

  on phase(Phase.Complete) -> {
    stop()
  }
}
