-- single_file.skein
-- The market_research example as ONE file: the agent is nested inside the
-- module (spec section 8.4 shape). The two-file version (service.skein +
-- agent.skein) is equivalent -- both shapes work.

module MarketResearch {
  capability http.in
  capability tool.use(Research.SearchMarket)
  capability tool.use(Research.AnalyzeCompetitor)
  capability tool.use(Research.GenerateSwot)

  type ResearchRequest {
    topic: String
    industry: String
    focus_areas: String
  }

  type ResumeRequest {
    refined_topic: String
    notes: String
  }

  -- Tool: Search market data for a given industry and topic
  tool Research.SearchMarket {
    description: "Search market data for competitors, trends, and market size"

    input {
      topic: String @description("Research topic")
      industry: String @description("Target industry")
    }

    output {
      competitors: String
      market_size: String
      trends: String
    }

    errors { SearchError }

    implement {
      let result = http.post("https://api.research.example/market/search", {
        query: topic,
        sector: industry
      })
      match result {
        Ok(r) -> Ok({
          competitors: r.body.competitors,
          market_size: r.body.market_size,
          trends: r.body.trends
        })
        Err(e) -> Err(SearchError.from(e))
      }
    }
  }

  -- Tool: Analyze a specific competitor
  tool Research.AnalyzeCompetitor {
    description: "Deep analysis of a specific competitor's positioning and strategy"

    input {
      competitor_name: String @description("Name of competitor to analyze")
      market_context: String @description("Market context for analysis")
    }

    output {
      strengths: String
      weaknesses: String
      positioning: String
      strategy: String
    }

    errors { AnalysisError }

    implement {
      let result = http.post("https://api.research.example/competitor/analyze", {
        name: competitor_name,
        context: market_context
      })
      match result {
        Ok(r) -> Ok({
          strengths: r.body.strengths,
          weaknesses: r.body.weaknesses,
          positioning: r.body.positioning,
          strategy: r.body.strategy
        })
        Err(e) -> Err(AnalysisError.from(e))
      }
    }
  }

  -- Tool: Generate SWOT analysis from collected data
  tool Research.GenerateSwot {
    description: "Generate a SWOT analysis from competitive research data"

    input {
      analysis_data: String @description("Compiled competitive analysis data")
      market_trends: String @description("Current market trends")
    }

    output {
      strengths: String
      weaknesses: String
      opportunities: String
      threats: String
      summary: String
    }

    errors { SwotError }

    implement {
      let result = http.post("https://api.research.example/swot/generate", {
        data: analysis_data,
        trends: market_trends
      })
      match result {
        Ok(r) -> Ok({
          strengths: r.body.strengths,
          weaknesses: r.body.weaknesses,
          opportunities: r.body.opportunities,
          threats: r.body.threats,
          summary: r.body.summary
        })
        Err(e) -> Err(SwotError.from(e))
      }
    }
  }

  -- Start a new research task
  handler http POST "/research/start" (req) -> {
    let brief = req.json[ResearchRequest]!
    trace.annotate("research_started", brief)
    respond.json(201, brief)
  }

  -- Get research status by ID
  handler http GET "/research/status" (req) -> {
    trace.annotate("status_checked", "ok")
    respond.json(200, "status_placeholder")
  }

  -- Resume a suspended research agent
  handler http POST "/research/resume" (req) -> {
    let body = req.json[ResumeRequest]!
    trace.annotate("research_resumed", body)
    respond.json(200, body)
  }

  supervisor Main {
    child HttpServer { restart: permanent }
    child AgentPool(MarketResearchAgent) { max: 100, restart: transient }
    strategy: one_for_one
    max_restarts: 5 per 60s
  }

  -- The agent, nested in the module: compiles to Skein.Agent.MarketResearch.MarketResearchAgent
  agent MarketResearchAgent {
    capability model("anthropic", "claude-opus-4-8")
    capability memory.kv
    capability tool.use(Research.SearchMarket)
    capability tool.use(Research.AnalyzeCompetitor)
    capability tool.use(Research.GenerateSwot)

    state {
      topic: String
      industry: String
    }

    enum Phase {
      Briefing   -> [Gathering]
      Gathering  -> [Analyzing, Briefing]
      Analyzing  -> [Reporting, Gathering]
      Reporting  -> [Complete]
      Complete   -> []
    }

    on start(topic: String, industry: String) -> {
      memory.put("topic", topic)
      memory.put("industry", industry)
      transition(Phase.Briefing)
    }

    on phase(Phase.Briefing) -> {
      let topic = memory.get!("topic")
      let industry = memory.get!("industry")

      -- Ask LLM if scope is focused enough
      let scope_check = llm.chat(
        "claude-opus-4-8",
        "Is this research scope focused enough for a competitive analysis? Answer only 'yes' or 'no'.",
        topic
      )!
      memory.put("scope_check", scope_check)

      let is_too_broad = String.contains(scope_check, "no")
      match is_too_broad {
        true -> {
          memory.put("phase_status", "suspended_scope_refinement")
          suspend("Requires human scope refinement")
        }
        false -> {
          memory.put("phase_status", "briefing_complete")
          transition(Phase.Gathering)
        }
      }
    }

    on phase(Phase.Gathering) -> {
      let topic = memory.get!("topic")
      let industry = memory.get!("industry")

      -- Use tool to search market data
      let search_result = tool.call(Research.SearchMarket, {
        topic: topic,
        industry: industry
      })

      match search_result {
        Ok(data) -> {
          memory.put("competitors", data.competitors)
          memory.put("market_size", data.market_size)
          memory.put("trends", data.trends)
          emit MarketDataGathered { topic: topic }
          transition(Phase.Analyzing)
        }
        Err(e) -> {
          memory.put("phase_status", "gathering_failed")
          suspend("Market search failed — requires human intervention")
        }
      }
    }

    on phase(Phase.Analyzing) -> {
      let competitors = memory.get!("competitors")
      let topic = memory.get!("topic")

      -- Use tool to analyze competitors
      let analysis_result = tool.call(Research.AnalyzeCompetitor, {
        competitor_name: competitors,
        market_context: topic
      })

      match analysis_result {
        Ok(analysis) -> {
          memory.put("analysis", analysis)
          emit AnalysisComplete { topic: topic }
          transition(Phase.Reporting)
        }
        Err(e) -> {
          memory.put("phase_status", "analysis_failed")
          suspend("Competitor analysis failed — requires human review")
        }
      }
    }

    on phase(Phase.Reporting) -> {
      let analysis = memory.get!("analysis")
      let trends = memory.get!("trends")

      -- Use tool to generate SWOT analysis
      let swot_result = tool.call(Research.GenerateSwot, {
        analysis_data: analysis,
        market_trends: trends
      })

      match swot_result {
        Ok(swot) -> {
          memory.put("swot", swot)
          memory.put("phase_status", "report_complete")
          let topic = memory.get!("topic")
          emit ReportGenerated { topic: topic }
          transition(Phase.Complete)
        }
        Err(e) -> {
          memory.put("phase_status", "reporting_failed")
          suspend("SWOT generation failed — requires human review")
        }
      }
    }

    on phase(Phase.Complete) -> {
      stop()
    }
  }
}
