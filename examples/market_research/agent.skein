-- agent.skein
-- Market Research Agent: pure workflow logic using tools for data gathering.
-- Follows the spec section 8.4 pattern — agent calls tools, knows nothing about HTTP.

agent MarketResearchAgent {
  capability model("anthropic", "claude-opus-4-8")
  capability memory.kv
  capability tool.use(Research.SearchMarket)
  capability tool.use(Research.AnalyzeCompetitor)
  capability tool.use(Research.GenerateSwot)

  state {
    topic: String
    industry: String
  }

  enum Phase {
    Briefing   -> [Gathering]
    Gathering  -> [Analyzing, Briefing]
    Analyzing  -> [Reporting, Gathering]
    Reporting  -> [Complete]
    Complete   -> []
  }

  on start(topic: String, industry: String) -> {
    memory.put("topic", topic)
    memory.put("industry", industry)
    transition(Phase.Briefing)
  }

  on phase(Phase.Briefing) -> {
    let topic = memory.get("topic")
    let industry = memory.get("industry")

    -- Ask LLM if scope is focused enough
    let scope_check = llm.chat(
      "claude-opus-4-8",
      "Is this research scope focused enough for a competitive analysis? Answer only 'yes' or 'no'.",
      topic
    )
    memory.put("scope_check", scope_check)

    let is_too_broad = String.contains(scope_check, "no")
    match is_too_broad {
      true -> {
        memory.put("phase_status", "suspended_scope_refinement")
        suspend("Requires human scope refinement")
      }
      false -> {
        memory.put("phase_status", "briefing_complete")
        transition(Phase.Gathering)
      }
    }
  }

  on phase(Phase.Gathering) -> {
    let topic = memory.get("topic")
    let industry = memory.get("industry")

    -- Use tool to search market data
    let search_result = tool.call(Research.SearchMarket, {
      topic: topic,
      industry: industry
    })

    match search_result {
      Ok(data) -> {
        memory.put("competitors", data.competitors)
        memory.put("market_size", data.market_size)
        memory.put("trends", data.trends)
        emit MarketDataGathered { topic: topic }
        transition(Phase.Analyzing)
      }
      Err(e) -> {
        memory.put("phase_status", "gathering_failed")
        suspend("Market search failed — requires human intervention")
      }
    }
  }

  on phase(Phase.Analyzing) -> {
    let competitors = memory.get("competitors")
    let topic = memory.get("topic")

    -- Use tool to analyze competitors
    let analysis_result = tool.call(Research.AnalyzeCompetitor, {
      competitor_name: competitors,
      market_context: topic
    })

    match analysis_result {
      Ok(analysis) -> {
        memory.put("analysis", analysis)
        emit AnalysisComplete { topic: topic }
        transition(Phase.Reporting)
      }
      Err(e) -> {
        memory.put("phase_status", "analysis_failed")
        suspend("Competitor analysis failed — requires human review")
      }
    }
  }

  on phase(Phase.Reporting) -> {
    let analysis = memory.get("analysis")
    let trends = memory.get("trends")

    -- Use tool to generate SWOT analysis
    let swot_result = tool.call(Research.GenerateSwot, {
      analysis_data: analysis,
      market_trends: trends
    })

    match swot_result {
      Ok(swot) -> {
        memory.put("swot", swot)
        memory.put("phase_status", "report_complete")
        let topic = memory.get("topic")
        emit ReportGenerated { topic: topic }
        transition(Phase.Complete)
      }
      Err(e) -> {
        memory.put("phase_status", "reporting_failed")
        suspend("SWOT generation failed — requires human review")
      }
    }
  }

  on phase(Phase.Complete) -> {
    stop()
  }
}
