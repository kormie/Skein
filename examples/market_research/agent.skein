-- market_research_agent.skein
-- A multi-phase agent for conducting competitive market research.
-- Demonstrates multi-phase transitions, memory accumulation, LLM analysis,
-- suspend/resume for human refinement, and looping between phases.

agent MarketResearchAgent {
  capability model("anthropic", "claude-sonnet-4-5")
  capability memory.kv

  state {
    topic: String
    industry: String
    focus_areas: String
  }

  enum Phase {
    Briefing -> [Gathering]
    Gathering -> [Analyzing, Briefing]
    Analyzing -> [Gathering, Reporting]
    Reporting -> [Complete]
    Complete -> []
  }

  on start(topic: String) -> {
    memory.put("topic", topic)
    memory.put("phase_status", "started")
    trace.annotate("agent_started", topic)
    transition(Phase.Briefing)
  }

  on phase(Phase.Briefing) -> {
    let topic = memory.get("topic")
    trace.annotate("research_topic", topic)
    trace.annotate("phase", "briefing")
    memory.put("phase_status", "briefing_complete")
    transition(Phase.Gathering)
  }

  on phase(Phase.Gathering) -> {
    let topic = memory.get("topic")
    trace.annotate("phase", "gathering")
    let scope_check = llm.chat("claude-sonnet-4-5", "Is this research scope focused enough for a competitive analysis? Answer only 'yes' or 'no'.", topic)
    trace.annotate("scope_check_result", scope_check)
    memory.put("scope_check", scope_check)
    let is_too_broad = String.contains(scope_check, "no")
    match is_too_broad {
      true -> {
        trace.annotate("scope_status", "too_broad")
        memory.put("phase_status", "suspended_scope_refinement")
        suspend("Requires human scope refinement")
      }
      false -> {
        let competitors = llm.chat("claude-sonnet-4-5", "Identify top competitors for this market", topic)
        trace.annotate("competitors_identified", competitors)
        memory.put("competitors", competitors)
        memory.put("phase_status", "gathering_complete")
        emit CompetitorsIdentified { topic: topic }
        transition(Phase.Analyzing)
      }
    }
  }

  on phase(Phase.Analyzing) -> {
    let topic = memory.get("topic")
    let competitors = memory.get("competitors")
    trace.annotate("phase", "analyzing")
    let analysis = llm.chat("claude-sonnet-4-5", "Analyze competitive landscape: strengths, weaknesses, positioning", competitors)
    trace.annotate("analysis_complete", analysis)
    memory.put("analysis", analysis)
    let swot = llm.chat("claude-sonnet-4-5", "Generate SWOT analysis from competitive data", analysis)
    trace.annotate("swot_generated", swot)
    memory.put("swot", swot)
    memory.put("phase_status", "analysis_complete")
    emit AnalysisComplete { topic: topic }
    transition(Phase.Reporting)
  }

  on phase(Phase.Reporting) -> {
    let topic = memory.get("topic")
    let analysis = memory.get("analysis")
    let swot = memory.get("swot")
    trace.annotate("phase", "reporting")
    let report = llm.chat("claude-sonnet-4-5", "Generate final market research report with recommendations", analysis)
    trace.annotate("report_generated", report)
    memory.put("report", report)
    memory.put("phase_status", "report_generated")
    emit ReportGenerated { topic: topic }
    transition(Phase.Complete)
  }

  on phase(Phase.Complete) -> {
    trace.annotate("phase", "complete")
    stop()
  }
}
