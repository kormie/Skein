-- skein_assistant.skein
-- A stateful conversational service that helps people write Skein code.
-- Takes questions about Skein via HTTP, uses LLM to generate answers,
-- and remembers conversation context across requests per session by
-- feeding the stored history back into each prompt.

module SkeinAssistant {
  capability http.in
  capability model("anthropic", "claude-opus-4-8")
  capability memory.kv

  -- Ask a question about Skein. Session history is stored in memory and
  -- interpolated into the prompt so follow-up questions have context.
  handler http POST "/ask" (req) -> {
    let session_id = req.params.session_id
    let question = req.body
    let history = Result.unwrap(memory.get(session_id), "")
    let prompt = "You are a Skein programming language assistant. Help the user write correct Skein code. Answer concisely. Conversation so far: ${history}"
    let answer = llm.chat("claude-opus-4-8", prompt, question)!
    memory.put(session_id, "${history} Q: ${question} A: ${answer}")
    respond.json(200, answer)
  }

  -- Get conversation history for a session.
  handler http GET "/history/:session_id" (req) -> {
    let session_id = req.params.session_id
    let history = Result.unwrap(memory.get(session_id), "")
    respond.json(200, history)
  }

  -- Health check endpoint.
  handler http GET "/health" (req) -> {
    respond.text(200, "ok")
  }
}
